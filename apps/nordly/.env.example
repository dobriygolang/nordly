# Copy to `.env`:  cp .env.example .env

# Default: prod API (https://trynordly.app) via Vite proxy — no local backend needed.

# Direct API base (skip proxy). Usually leave unset in dev.
# VITE_NORDLY_API_BASE=http://localhost:8080

# Local-only data mode (default true): notes/tasks/focus stay on-device, cloud
# integrations (incl. Google Calendar settings section) are hidden. Set false to
# enable cloud APIs and show the Google Calendar integration.
# VITE_NORDLY_LOCAL_ONLY=false

# Local microservices stack (identity, tracker, notes, focus):
# VITE_NORDLY_LOCAL_API=true

# Public web companion URL (required for whiteboard live share links):
VITE_NORDLY_WEB_BASE=https://trynordly.app
