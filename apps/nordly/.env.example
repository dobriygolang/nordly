# Copy to `.env`:  cp .env.example .env

# Default: prod API (https://trynordly.app) via Vite proxy — no local backend needed.

# Direct API base (skip proxy). Usually leave unset in dev.
# VITE_NORDLY_API_BASE=http://localhost:8080

# Local microservices stack (identity, tracker, notes, focus):
# VITE_NORDLY_LOCAL_API=true

# Telegram bot @username fallback when /v1/auth/config fails:
VITE_TELEGRAM_BOT_USERNAME=nordly_bot

# Dev login panel on login screen (identity DEV_AUTH=true on backend):
VITE_NORDLY_DEV_LOGIN=true

# Public web companion URL:
# VITE_NORDLY_WEB_BASE=http://localhost:5173

# RPC debug bearer (optional):
# VITE_NORDLY_DEV_TOKEN=
