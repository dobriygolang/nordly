{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main Nordly window capabilities (bundled + Vite dev server)",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:5173",
      "http://localhost:5173/**",
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5173/**"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "allow-nordly-main-commands",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://trynordly.app/**" },
        { "url": "https://api.trynordly.app/**" },
        { "url": "https://cdn.trynordly.app/**" },
        { "url": "http://localhost:8080/**" },
        { "url": "http://127.0.0.1:8080/**" }
      ]
    }
  ]
}
