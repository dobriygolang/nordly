{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "notification",
  "description": "Least-privilege capabilities for the notification window",
  "windows": ["notification"],
  "remote": {
    "urls": [
      "http://localhost:5173",
      "http://localhost:5173/**",
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5173/**"
    ]
  },
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "allow-nordly-notification-commands"
  ]
}
