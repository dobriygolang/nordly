# API base path (production: same-origin /v1 via Caddy)
VITE_API_BASE=/v1

# Nordly desktop download (optional — landing resolves latest GitHub release automatically)
# VITE_NORDLY_DOWNLOAD_MAC=https://example.com/Nordly.dmg
# VITE_NORDLY_DOWNLOAD_WIN=https://example.com/Nordly-setup.exe

# Canonical site URL for SEO meta tags (production default: https://trynordly.app)
# VITE_SITE_ORIGIN=https://trynordly.app

# Landing hero media (optional — falls back to animated preview)
# VITE_NORDLY_HERO_VIDEO=/hero.mp4
# VITE_NORDLY_HERO_POSTER=/hero-poster.jpg

# Per-service overrides for vite dev proxy
# VITE_IDENTITY_URL=http://localhost:8080
# VITE_BILLING_URL=http://localhost:8085
# VITE_SANDBOX_URL=http://localhost:8086
# VITE_ROOMS_URL=http://localhost:8087
# VITE_NOTES_URL=http://localhost:8090

# Optional explicit WebSocket base for live rooms
# VITE_WS_BASE=ws://localhost:8087
