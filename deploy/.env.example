# =============================================================================
# nordly production — copy to deploy/.env and fill values
# cp deploy/.env.example deploy/.env
# =============================================================================

APP_ENV=production
LOG_LEVEL=info
GRPC_HOST=0.0.0.0

# openssl rand -hex 32
INTERNAL_API_TOKEN=CHANGE_ME

POSTGRES_USER=nordly
POSTGRES_PASSWORD=CHANGE_ME

IDENTITY_POSTGRES_DSN=postgres://nordly:CHANGE_ME@postgres:5432/nordly?sslmode=disable
BILLING_POSTGRES_DSN=postgres://nordly:CHANGE_ME@postgres:5432/nordly_billing?sslmode=disable
TRIBUTE_WEBHOOK_SECRET=
# When empty, /v1/billing/webhooks/tribute returns 401 until you set a secret.
TRIBUTE_TIER_MAP=tribute_pro_monthly:pro_monthly
# Tribute Creator → Links → Web / Telegram Mini App (shown on /pricing).
TRIBUTE_PRO_CHECKOUT_URL=
TRIBUTE_PRO_TELEGRAM_CHECKOUT_URL=
# Optional multi-plan maps (plan_slug=https://..., use = not : — URLs contain colons):
# TRIBUTE_CHECKOUT_URLS=pro_monthly=https://web.tribute.tg/p/XXX
# TRIBUTE_TELEGRAM_CHECKOUT_URLS=pro_monthly=https://t.me/tribute/app?startapp=XXX
# Webhook URL in Tribute dashboard: https://api.trynordly.app/v1/billing/webhooks/tribute

# One-time Pro trial promo (shown on /pricing, POST /v1/billing/trial/start).
PRO_TRIAL_ENABLED=true
PRO_TRIAL_DAYS=14
# Optional Redis entitlements cache (billing service; shared redis with identity).
ENTITLEMENTS_CACHE_TTL=60s
SANDBOX_POSTGRES_DSN=postgres://nordly:CHANGE_ME@postgres:5432/nordly_sandbox?sslmode=disable
ROOMS_POSTGRES_DSN=postgres://nordly:CHANGE_ME@postgres:5432/nordly_rooms?sslmode=disable
TRACKER_POSTGRES_DSN=postgres://nordly:CHANGE_ME@postgres:5432/nordly_tracker?sslmode=disable
NOTES_POSTGRES_DSN=postgres://nordly:CHANGE_ME@postgres:5432/nordly_notes?sslmode=disable
FOCUS_POSTGRES_DSN=postgres://nordly:CHANGE_ME@postgres:5432/nordly_focus?sslmode=disable
GUEST_ROOM_TTL=3h
ROOM_ARCHIVE_INTERVAL=1m
PUBLIC_BASE_URL=https://trynordly.app
# Public links for notes publish + rooms live/board URLs (notes + rooms services)
SANDBOX_RUNNER_MODE=docker
SANDBOX_ASYNC_RUNS=auto
SANDBOX_MAX_OUTPUT_BYTES=65536
SANDBOX_DEFAULT_TIMEOUT_MS=10000
SANDBOX_DOCKER_GO_IMAGE=golang:1.24-alpine
SANDBOX_DOCKER_PYTHON_IMAGE=python:3.12-alpine
SANDBOX_DOCKER_NODE_IMAGE=node:22-alpine
# Host dir for docker runner bind mounts (must match deploy/docker-compose.prod.yml volume).
# mkdir -p /var/lib/sandbox-work && chmod 700 /var/lib/sandbox-work

FRONTEND_URL=https://trynordly.app
# Identity OAuth redirect base (web login flows)
# Google Calendar OAuth callback target for Nordly desktop (web bridge → deep link)
NORDLY_CALLBACK_URL=https://trynordly.app/oauth/google-calendar
# Zoom OAuth uses the same host with /oauth/zoom (tracker derives path automatically)
CORS_ALLOWED_ORIGINS=https://trynordly.app,https://app.trynordly.app
AUTH_RATE_LIMIT_PER_MINUTE=60

TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_BOT_USERNAME=CHANGE_ME_bot

YANDEX_CLIENT_ID=CHANGE_ME
YANDEX_CLIENT_SECRET=CHANGE_ME
YANDEX_REDIRECT_URI=https://api.trynordly.app/v1/auth/yandex/callback

# Encrypts Google/Zoom refresh tokens at rest (recommended for production).
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=CHANGE_ME

# Tracker Google Calendar (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://trynordly.app/v1/tracker/integrations/google/callback

# Tracker Zoom meetings (optional — leave empty to disable)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=https://trynordly.app/v1/tracker/integrations/zoom/callback

CADDY_EMAIL=admin@trynordly.app
# Caddy HTTP on localhost only (host nginx keeps 80/443 for VPN). See deploy/nginx-trynordly.conf.example.
CADDY_HTTP_PORT=18080

# Grafana Cloud (optional — enable with: docker compose --profile monitoring up -d alloy)
# Get credentials: Grafana Cloud → Connections → Prometheus → Remote write
GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_PROMETHEUS_USER=
GRAFANA_CLOUD_PROMETHEUS_API_KEY=
GRAFANA_CLOUD_STACK_URL=
GRAFANA_CLOUD_API_KEY=
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=https://grafana.trynordly.app/
