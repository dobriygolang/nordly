{
	email {$CADDY_EMAIL}
	# Host nginx keeps :80/:443 (e.g. VPN). TLS terminates in nginx; Caddy is HTTP-only behind it.
	auto_https off
}

# Shared API routing (used on api.* and on the SPA host for same-origin /v1).
(api_v1) {
	handle /v1/auth* {
		reverse_proxy identity:8080
	}
	handle /v1/me* {
		reverse_proxy identity:8080
	}
	handle /v1/users* {
		reverse_proxy identity:8080
	}
	handle /v1/jwt* {
		reverse_proxy identity:8080
	}
	handle /v1/devices* {
		reverse_proxy identity:8080
	}
	handle /v1/rooms* {
		reverse_proxy rooms:8087
	}
	handle /v1/sandbox* {
		reverse_proxy sandbox:8086
	}
	handle /v1/billing* {
		reverse_proxy billing:8085
	}
	handle /v1/tracker* {
		reverse_proxy tracker:8089
	}
	handle /v1/notes* {
		reverse_proxy notes:8090
	}
	handle /v1/focus* {
		reverse_proxy focus:8091
	}
	handle /v1/* {
		header Content-Type application/json
		respond "{\"error\":\"not found\"}" 404
	}
}

(api_ws) {
	handle /ws/lsp/* {
		reverse_proxy sandbox:8086
	}
	handle /ws/* {
		reverse_proxy rooms:8087
	}
}

# API — primary: api.trynordly.app
http://api.trynordly.app {
	encode gzip
	import api_v1
	import api_ws
	handle /healthz {
		respond "ok" 200
	}
	respond "not found" 404
}

# SPA — canonical: trynordly.app (same-origin /v1 for VITE_API_BASE=/v1)
http://trynordly.app, http://app.trynordly.app {
	encode gzip
	route {
		import api_v1
		import api_ws
		handle /desktop/* {
			root * /cdn
			header Cache-Control "public, max-age=3600"
			@manifest path /desktop/latest.json /desktop/releases.json
			handle @manifest {
				header Cache-Control "public, max-age=60"
				file_server
			}
			file_server
		}
		handle {
			root * /srv
			try_files {path} /index.html
			file_server
		}
	}
}

# Grafana — monitoring UI (TLS at host nginx)
http://grafana.trynordly.app {
	encode gzip
	reverse_proxy grafana:3000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto https
	}
}

# Optional CDN host — requires TLS cert SAN for cdn.trynordly.app (see deploy/nginx-trynordly.conf.example).
# Desktop downloads are served on trynordly.app/desktop/* (same cert as the landing).
http://cdn.trynordly.app {
	encode gzip
	root * /cdn
	header Cache-Control "public, max-age=3600"
	@updater path /desktop/latest.json /desktop/releases.json
	handle @updater {
		header Cache-Control "public, max-age=60"
		file_server
	}
	file_server
}
