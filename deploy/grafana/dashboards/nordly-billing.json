{
  "uid": "nordly-billing",
  "title": "nordly — Billing",
  "tags": ["nordly", "billing", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "row",
      "title": "Catalog cache",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Plans cache hit rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(billing_plans_cache_hits_total[5m])",
          "legendFormat": "hits"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(billing_plans_cache_misses_total[5m])",
          "legendFormat": "misses"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Plans snapshot reloads",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (result) (rate(billing_plans_reload_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Entitlements",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Entitlements Redis vs Postgres",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(billing_entitlements_redis_hits_total[5m])",
          "legendFormat": "redis hits"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(billing_entitlements_redis_misses_total[5m])",
          "legendFormat": "postgres loads"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Plans snapshot size (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "billing_plans_snapshot_bytes",
          "legendFormat": "snapshot"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Billing HTTP RPS",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{service=\"billing\"}[5m]))",
          "legendFormat": "total"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{service=\"billing\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Billing HTTP p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"billing\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
